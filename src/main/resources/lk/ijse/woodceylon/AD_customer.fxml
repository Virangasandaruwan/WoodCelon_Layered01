<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="780.0" prefWidth="1274.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.woodceylon.controller.AD_customerController">
   <children>
      <AnchorPane fx:id="AD_customer" prefHeight="780.0" prefWidth="1274.0" stylesheets="@../../../css/login.css">
         <children>
            <Label layoutX="100.0" layoutY="156.0" text="Email" textFill="#0c7e7e" />
            <Label layoutX="99.0" layoutY="199.0" text="Customer ID" textFill="#0c7e7e" />
            <Label layoutX="100.0" layoutY="251.0" text="Customer Name" textFill="#0c7e7e" />
            <Label layoutX="99.0" layoutY="304.0" text="Address" textFill="#0c7e7e" />
            <Label layoutX="100.0" layoutY="356.0" text="Contact" textFill="#0c7e7e" />

            <TableView fx:id="tableCustomer" layoutX="118.0" layoutY="556.0" prefHeight="162.0" prefWidth="838.0" style="-fx-border-color: #149494;" styleClass="white-form" stylesheets="@../../../css/login.css">
               <columns>
                  <TableColumn fx:id="colName" prefWidth="162.0" text="Customer Name" />
                  <TableColumn fx:id="colNumber" prefWidth="123.0" text="Phone" />
                  <TableColumn fx:id="colAddress" prefWidth="190.0" text="Address" />
                  <TableColumn fx:id="colId" prefWidth="63.0" text="ID" />
                  <TableColumn fx:id="colEmail" prefWidth="298.4" text="Email" />
               </columns>
            </TableView>
            
            <TextField fx:id="customerEmail" layoutX="198.0" layoutY="147.0" prefHeight="26.0" prefWidth="274.0" promptText="Example@gmail.com" />
            <TextField fx:id="customerAddress" layoutX="198.0" layoutY="304.0" prefHeight="26.0" prefWidth="274.0" />
            <TextField fx:id="idField" layoutX="198.0" layoutY="199.0" onKeyReleased="#handleSearchCustomer" prefHeight="26.0" prefWidth="274.0" />
            <TextField fx:id="customerName" layoutX="198.0" layoutY="251.0" prefHeight="26.0" prefWidth="274.0" />
            <TextField fx:id="customerNumber" layoutX="197.0" layoutY="356.0" prefHeight="26.0" prefWidth="274.0" promptText="0XX  XXXXXX" />
            
            <Button fx:id="btnSave" layoutX="514.0" layoutY="246.0" onAction="#saveCustomer" prefWidth="100.0" style="-fx-background-color: #149494;" text="Add" textFill="WHITE" />
            <Button fx:id="btnUpdate" layoutX="514.0" layoutY="282.0" onAction="#handleCustomerUpdate" prefWidth="100.0" style="-fx-background-color: #149494;" text="Update" textFill="WHITE" />
            <Button fx:id="btnDelete" layoutX="514.0" layoutY="317.0" onAction="#handleCustomerDelete" prefWidth="100.0" style="-fx-background-color: #149494;" text="Delete" textFill="WHITE" />
            <Button fx:id="btnReset" layoutX="514.0" layoutY="352.0" onAction="#handleCustomerReset" prefWidth="100.0" style="-fx-background-color: #149494;" text="Reset" textFill="WHITE" />
            <Button fx:id="btnPrint" layoutX="668.0" layoutY="357.0" mnemonicParsing="false" onAction="#handlePrintCustomer" prefHeight="26.0" prefWidth="196.0" style="-fx-background-color: #149494;" text="Print Customer Report" textFill="WHITE" />
            
            <VBox alignment="TOP_CENTER" layoutX="0.0" layoutY="0.0" prefHeight="90.0" prefWidth="1269.0" style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-background-color: #b2e6ce;">
               <children>
                  <Label prefHeight="35.0" styleClass="head-label" stylesheets="@../../../css/login.css" text="Add New Customers" textFill="#149494">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets top="24.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>

            <VBox layoutX="0.0" layoutY="419.0" prefHeight="90.0" prefWidth="1269.0" style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-background-color: #b2e0df;">
               <children>
                  <Label prefHeight="35.0" styleClass="head-label" stylesheets="@../../../css/login.css" text="Customer details Table" textFill="#149494">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                     <VBox.margin>
                        <Insets left="30.0" top="24.0" />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </children>
</StackPane>
